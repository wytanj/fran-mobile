# ─── Client (Expo) ───────────────────────────────────────────
# Leave TWILIO off until Singapore SMS launch. Demo OTP is always 1234.
EXPO_PUBLIC_TWILIO_AUTH_ENABLED=false

# Base URL for auth API (Vercel). Empty = same origin on web.
# For native builds against production API, set e.g.:
# EXPO_PUBLIC_AUTH_API_URL=https://fran-mobile.vercel.app
EXPO_PUBLIC_AUTH_API_URL=

# ─── Server only (Vercel project env — never EXPO_PUBLIC_) ───
# Flip when ready to send real SMS via Twilio Verify (SMS, SG first).
TWILIO_AUTH_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Verify Service: set code length to 4 digits in Twilio Console
TWILIO_VERIFY_SERVICE_SID=

# Staging only: allow demo code 1234 while Twilio is live
ALLOW_DEMO_OTP_WHEN_LIVE=false
